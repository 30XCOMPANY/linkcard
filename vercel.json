{
    "version": 2,
    "buildCommand": "npm run build:web",
    "outputDirectory": "dist",
    "cleanUrls": true,
    "trailingSlash": false,
    "functions": {
        "api/index.ts": {
            "maxDuration": 15
        }
    },
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/index.ts"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}