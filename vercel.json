{
    "version": 2,
    "buildCommand": "npm run build:web",
    "outputDirectory": "dist",
    "cleanUrls": true,
    "trailingSlash": false,
    "functions": {
        "api/src/index.ts": {
            "maxDuration": 15
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "api/src/index.ts"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "index.html"
        }
    ]
}